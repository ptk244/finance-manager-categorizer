# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_CATEGORIZATION=gemini-1.5-pro
GEMINI_MODEL_INSIGHTS=gemini-1.5-flash

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# File Upload Configuration
MAX_FILE_SIZE=50MB
ALLOWED_EXTENSIONS=.csv,.xlsx,.xls,.pdf

# Agno Configuration
AGNO_LOG_LEVEL=INFO